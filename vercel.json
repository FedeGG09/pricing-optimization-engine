{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "excludeFiles": "{**/__pycache__/**,**/*.pyc,**/*.pyo,**/*.zip,**/*.rar,**/*.7z,**/*.tar,**/*.gz,public/**,sullair_pricing_front/**,tests/**,__tests__/**,**/*.test.py,**/test_*.py,fixtures/**,__fixtures__/**,artifacts_test4/**,docker/**,docker-compose.yml,ARCHITECTURE.md,EXAMPLES.md}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ]
}
